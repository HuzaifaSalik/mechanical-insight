# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production

# Database
# For local development, SQLite is used
# For production (Render), PostgreSQL will be auto-configured
DATABASE_URL=sqlite:///companyinsight.db

# Email Configuration (Gmail)
# You need to create an App Password for Gmail
# Instructions: https://support.google.com/accounts/answer/185833
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=noreply@companyinsight.com

# Admin Credentials (for initial setup)
ADMIN_EMAIL=admin@companyinsight.com
ADMIN_PASSWORD=change-this-secure-password

# Google reCAPTCHA (Optional but recommended)
# Get your keys from: https://www.google.com/recaptcha/admin
RECAPTCHA_PUBLIC_KEY=your-recaptcha-site-key
RECAPTCHA_PRIVATE_KEY=your-recaptcha-secret-key
